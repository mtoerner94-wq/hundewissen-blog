---
interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
  baseUrl: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props;

function pageUrl(page: number): string {
  if (page === 1) return `${baseUrl}/`;
  return `${baseUrl}/${page}/`;
}

function getPageNumbers(current: number, last: number): (number | '...')[] {
  if (last <= 7) {
    return Array.from({ length: last }, (_, i) => i + 1);
  }

  const pages: (number | '...')[] = [1];

  if (current > 3) {
    pages.push('...');
  }

  const start = Math.max(2, current - 1);
  const end = Math.min(last - 1, current + 1);

  for (let i = start; i <= end; i++) {
    pages.push(i);
  }

  if (current < last - 2) {
    pages.push('...');
  }

  pages.push(last);
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, lastPage);
---

<nav class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-8" aria-label="Seitennavigation">
  <div class="flex items-center justify-center gap-2">
    {prevUrl ? (
      <a href={prevUrl} class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-[var(--color-primary)] transition-colors duration-200">
        &larr; Zurück
      </a>
    ) : (
      <span class="px-3 py-2 text-sm font-medium text-slate-300 cursor-default">
        &larr; Zurück
      </span>
    )}

    {pageNumbers.map((page) =>
      page === '...' ? (
        <span class="px-2 py-2 text-sm text-slate-400">&hellip;</span>
      ) : page === currentPage ? (
        <span class="w-10 h-10 flex items-center justify-center text-sm font-semibold rounded-lg bg-[var(--color-primary)] text-white" aria-current="page">
          {page}
        </span>
      ) : (
        <a href={pageUrl(page)} class="w-10 h-10 flex items-center justify-center text-sm font-medium text-slate-600 rounded-lg hover:bg-slate-100 transition-colors duration-200">
          {page}
        </a>
      )
    )}

    {nextUrl ? (
      <a href={nextUrl} class="px-3 py-2 text-sm font-medium text-slate-600 hover:text-[var(--color-primary)] transition-colors duration-200">
        Weiter &rarr;
      </a>
    ) : (
      <span class="px-3 py-2 text-sm font-medium text-slate-300 cursor-default">
        Weiter &rarr;
      </span>
    )}
  </div>
</nav>
