---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EditorialSection from '../../components/EditorialSection.astro';
import Pagination from '../../components/Pagination.astro';

const gradientMap: Record<string, string> = {
  hundeernaehrung: 'from-orange-100 to-amber-50',
  reisen: 'from-sky-100 to-blue-50',
  'erziehung-verhalten': 'from-blue-100 to-indigo-50',
  hundeausstattung: 'from-teal-100 to-cyan-50',
  hunderassen: 'from-purple-100 to-violet-50',
  hundepflege: 'from-pink-100 to-fuchsia-50',
};

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  const categories = [
    { name: 'Hundeernährung', slug: 'hundeernaehrung', emoji: '🍖', seoTitle: 'Hundeernährung: Ratgeber für gesundes Hundefutter', description: 'Alles über die richtige Ernährung deines Hundes.' },
    { name: 'Reisen', slug: 'reisen', emoji: '✈️', seoTitle: 'Reisen mit Hund: Tipps & hundefreundliche Ziele', description: 'Reisen mit Hund – Tipps für Urlaub, Transport und hundefreundliche Ziele.' },
    { name: 'Erziehung & Verhalten', slug: 'erziehung-verhalten', emoji: '🎓', seoTitle: 'Hundeerziehung: Training & Verhaltenstipps', description: 'Training, Erziehung und Verhaltenstipps für deinen Hund.' },
    { name: 'Hundeausstattung', slug: 'hundeausstattung', emoji: '🦴', seoTitle: 'Hundeausstattung: Die beste Ausrüstung für deinen Hund', description: 'Die beste Ausstattung für deinen Vierbeiner.' },
    { name: 'Hunderassen', slug: 'hunderassen', emoji: '🐕', seoTitle: 'Hunderassen: Porträts & Rassenvergleiche', description: 'Rasseporträts und Rassenvergleiche für alle Hunderassen.' },
    { name: 'Hundepflege', slug: 'hundepflege', emoji: '🛁', seoTitle: 'Hundepflege: Fell, Baden & Gesundheit', description: 'Pflege, Baden und Fellpflege für deinen Hund.' },
  ];

  return categories.flatMap((cat) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.categorySlug === cat.slug)
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

    return paginate(filteredPosts, {
      params: { category: cat.slug },
      props: {
        categoryName: cat.name,
        categoryEmoji: cat.emoji,
        categorySeoTitle: cat.seoTitle,
        categoryDescription: cat.description,
      },
      pageSize: 9,
    });
  });
}) satisfies GetStaticPaths;

const { category } = Astro.params;
const { categoryName, categoryEmoji, categorySeoTitle, categoryDescription } = Astro.props;
const page = Astro.props.page;

const isFirstPage = page.currentPage === 1;

// Seite 1: 4 Bento-Grid + 5 Editorial-Liste = 9
// Folgeseiten: 9 Editorial-Liste
const bentoPosts = isFirstPage ? page.data.slice(0, 4) : [];
const editorialPosts = isFirstPage ? page.data.slice(4) : page.data;

const pageTitle = isFirstPage
  ? categorySeoTitle
  : `${categorySeoTitle} – Seite ${page.currentPage}`;
const pageDescription = categoryDescription;

const siteBase = 'https://hundewissen-mit-kopf.de';
const prevUrl = page.url.prev ? `${siteBase}${page.url.prev}` : undefined;
const nextUrl = page.url.next ? `${siteBase}${page.url.next}` : undefined;

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `${siteBase}/${category}/`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": `${siteBase}/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": categoryName,
      "item": `${siteBase}/${category}/`
    }
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemas={[collectionPageSchema, breadcrumbSchema]}
  noindex={!isFirstPage}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <!-- Breadcrumbs -->
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-4" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-slate-500">
      <li>
        <a href="/" class="hover:text-[var(--color-primary)] transition-colors">Startseite</a>
      </li>
      <li aria-hidden="true">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </li>
      <li>
        <span class="text-slate-900 font-medium">{categoryName}</span>
      </li>
    </ol>
  </nav>

  <!-- Category Header -->
  <header class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 border-b border-slate-200">
    <div>
      <span class="text-5xl mb-4 inline-block">{categoryEmoji}</span>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mt-2">
        {categoryName}
      </h1>
      <p class="text-xl italic text-slate-500 mt-5 max-w-2xl leading-relaxed">
        {categoryDescription}
      </p>
    </div>
  </header>

  <!-- Page indicator (page 2+) -->
  {!isFirstPage && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-4">
      <p class="text-sm text-slate-400">Seite {page.currentPage} von {page.lastPage}</p>
    </div>
  )}

  {page.data.length > 0 ? (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">

      {/* ── Bento Grid (Seite 1, Posts 1–4) ── */}
      {bentoPosts.length >= 3 && (() => {
        const main = bentoPosts[0];
        const side1 = bentoPosts[1];
        const side2 = bentoPosts[2];
        const fourth = bentoPosts[3];
        const mainGradient = gradientMap[main.data.categorySlug] || 'from-slate-100 to-slate-50';
        const side1Gradient = gradientMap[side1.data.categorySlug] || 'from-slate-100 to-slate-50';
        const side2Gradient = gradientMap[side2.data.categorySlug] || 'from-slate-100 to-slate-50';
        return (
          <div>
            {/* Top: 3-Post Bento */}
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
              {/* Main Post */}
              <a href={`/${main.data.categorySlug}/${main.id}/`} class="group lg:col-span-3 lg:row-span-2 flex flex-col">
                <div class="overflow-hidden rounded-lg">
                  {main.data.image
                    ? <Image src={main.data.image} alt={main.data.title} class="w-full aspect-[3/2] object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="eager" widths={[480, 720, 960]} sizes="(max-width: 1024px) 100vw, 60vw" />
                    : <div class={`w-full aspect-[3/2] bg-gradient-to-br ${mainGradient} rounded-lg`} />
                  }
                </div>
                <div class="pt-5 flex flex-col flex-1">
                  <h2 class="font-[var(--font-display)] font-bold text-2xl md:text-3xl text-slate-900 group-hover:text-[var(--color-primary)] transition-colors duration-200">{main.data.title}</h2>
                  <p class="text-slate-500 mt-3 line-clamp-2 text-base">{main.data.description}</p>
                  <time class="text-sm text-slate-400 mt-auto pt-4 block" datetime={new Date(main.data.date).toISOString()}>{formatDate(main.data.date)}</time>
                </div>
              </a>
              {/* Side Post 1 */}
              <a href={`/${side1.data.categorySlug}/${side1.id}/`} class="group lg:col-span-2 flex flex-col">
                <div class="overflow-hidden rounded-lg">
                  {side1.data.image
                    ? <Image src={side1.data.image} alt={side1.data.title} class="w-full aspect-[16/9] object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" widths={[320, 480]} sizes="(max-width: 1024px) 100vw, 40vw" />
                    : <div class={`w-full aspect-[16/9] bg-gradient-to-br ${side1Gradient} rounded-lg`} />
                  }
                </div>
                <div class="pt-4 flex flex-col flex-1">
                  <h3 class="font-[var(--font-display)] font-semibold text-lg text-slate-900 group-hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2">{side1.data.title}</h3>
                  <time class="text-sm text-slate-400 mt-auto pt-3 block" datetime={new Date(side1.data.date).toISOString()}>{formatDate(side1.data.date)}</time>
                </div>
              </a>
              {/* Side Post 2 */}
              <a href={`/${side2.data.categorySlug}/${side2.id}/`} class="group lg:col-span-2 flex flex-col">
                <div class="overflow-hidden rounded-lg">
                  {side2.data.image
                    ? <Image src={side2.data.image} alt={side2.data.title} class="w-full aspect-[16/9] object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" widths={[320, 480]} sizes="(max-width: 1024px) 100vw, 40vw" />
                    : <div class={`w-full aspect-[16/9] bg-gradient-to-br ${side2Gradient} rounded-lg`} />
                  }
                </div>
                <div class="pt-4 flex flex-col flex-1">
                  <h3 class="font-[var(--font-display)] font-semibold text-lg text-slate-900 group-hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2">{side2.data.title}</h3>
                  <time class="text-sm text-slate-400 mt-auto pt-3 block" datetime={new Date(side2.data.date).toISOString()}>{formatDate(side2.data.date)}</time>
                </div>
              </a>
            </div>

            {/* Post 4: Horizontal card */}
            {fourth && (() => {
              const fourthGradient = gradientMap[fourth.data.categorySlug] || 'from-slate-100 to-slate-50';
              return (
                <a href={`/${fourth.data.categorySlug}/${fourth.id}/`} class="group grid grid-cols-1 md:grid-cols-5 gap-6 mt-8">
                  <div class="md:col-span-2 overflow-hidden rounded-lg">
                    {fourth.data.image
                      ? <Image src={fourth.data.image} alt={fourth.data.title} class="w-full h-full aspect-[16/9] md:aspect-auto object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" widths={[320, 480, 640]} sizes="(max-width: 768px) 100vw, 40vw" />
                      : <div class={`w-full aspect-[16/9] md:aspect-auto md:h-full bg-gradient-to-br ${fourthGradient} rounded-lg`} />
                    }
                  </div>
                  <div class="md:col-span-3 flex flex-col justify-center">
                    <h3 class="font-[var(--font-display)] font-semibold text-xl text-slate-900 group-hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2">{fourth.data.title}</h3>
                    <p class="text-slate-500 mt-2 line-clamp-2 text-sm">{fourth.data.description}</p>
                    <time class="text-sm text-slate-400 mt-3 block" datetime={new Date(fourth.data.date).toISOString()}>{formatDate(fourth.data.date)}</time>
                  </div>
                </a>
              );
            })()}
          </div>
        );
      })()}

      {/* ── Editorial Liste ── */}
      {editorialPosts.length > 0 && (
        <div class="mt-16">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400 font-medium mb-2">Weitere Artikel</p>
          <div class="border-t border-slate-200 pt-2">
            <EditorialSection posts={editorialPosts} />
          </div>
        </div>
      )}

    </div>
  ) : (
    <div class="text-center py-16">
      <p class="text-slate-500 text-lg">
        In dieser Kategorie gibt es noch keine Artikel. Schau bald wieder vorbei!
      </p>
      <a href="/" class="inline-block mt-6 text-[var(--color-primary)] font-semibold hover:underline">
        Zur Startseite
      </a>
    </div>
  )}

  <!-- Pagination -->
  {page.lastPage > 1 && (
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      baseUrl={`/${category}`}
    />
  )}
</BaseLayout>
