---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Post {
  id: string;
  data: {
    title: string;
    description: string;
    category: string;
    categorySlug: string;
    date: Date;
    image?: ImageMetadata;
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

const gradientMap: Record<string, string> = {
  hundeernaehrung: 'from-orange-100 to-amber-50',
  reisen: 'from-sky-100 to-blue-50',
  'erziehung-verhalten': 'from-blue-100 to-indigo-50',
  hundeausstattung: 'from-teal-100 to-cyan-50',
  hunderassen: 'from-purple-100 to-violet-50',
  hundepflege: 'from-pink-100 to-fuchsia-50',
};

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<div>
  {posts.map((post) => {
    const gradient = gradientMap[post.data.categorySlug] || 'from-slate-100 to-slate-50';
    return (
      <a
        href={`/${post.data.categorySlug}/${post.id}/`}
        class="group flex flex-col sm:flex-row gap-5 sm:gap-8 py-7 border-b border-slate-100 last:border-b-0"
      >
        <div class="shrink-0 w-full sm:w-[240px] overflow-hidden rounded-lg">
          {post.data.image
            ? <Image src={post.data.image} alt={post.data.title} class="w-full aspect-[4/3] object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" widths={[240, 480]} sizes="(max-width: 640px) 100vw, 240px" />
            : <div class={`w-full aspect-[4/3] bg-gradient-to-br ${gradient}`} />
          }
        </div>
        <div class="flex flex-col justify-center min-w-0">
          <h3 class="font-[var(--font-display)] font-semibold text-xl text-slate-900 group-hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2">{post.data.title}</h3>
          <p class="text-sm text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
          <time class="text-sm text-slate-400 mt-3 block" datetime={new Date(post.data.date).toISOString()}>{formatDate(post.data.date)}</time>
        </div>
      </a>
    );
  })}
</div>
