---
interface Props {
  icon: string;
  title: string;
  description: string;
  tags: string[];
  href: string;
}

const { icon, title, description, tags, href } = Astro.props;
---

<a href={href} class="scroll-fade-in block group border border-slate-200 rounded-sm overflow-hidden" aria-label={`${title} – ${description}`}>
  <div class="p-6 text-center">
    <div class="text-5xl mb-4" aria-hidden="true">{icon}</div>
    <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-[var(--color-primary-text)] transition-colors duration-200">
      {title}
    </h3>
    <p class="text-sm text-slate-500 leading-relaxed mb-3">
      {description}
    </p>
    <div class="flex flex-wrap justify-center gap-2">
      {tags.map((tag) => (
        <span class="inline-block text-xs font-medium text-slate-500 border border-slate-200 px-2.5 py-1">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
